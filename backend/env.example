# Configuração do Servidor
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Configuração do Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Configuração do Banco de Dados
DATABASE_PATH=./database/ultimate_ticket.db

# Configuração de Segurança
JWT_SECRET=your_jwt_secret_here_minimum_32_characters_long
BCRYPT_ROUNDS=12

# Configuração de Email (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Ultimate Ticket <noreply@ultimateticket.com>

# Configuração de Logs
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Configuração de Upload (opcional)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# URLs de Redirecionamento
SUCCESS_URL=http://localhost:3000/confirmacao
CANCEL_URL=http://localhost:3000/checkout?canceled=true

# Configuração PIX
PIX_BANK_CODE=001
PIX_AGENCY=0001
PIX_ACCOUNT=12345678
PIX_ACCOUNT_TYPE=checking

# Configuração de Cache (opcional)
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# Configuração de Monitoramento (opcional)
SENTRY_DSN=https://your-sentry-dsn-here

# Configuração de Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100 